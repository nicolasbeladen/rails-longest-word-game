<div class="container">
<h1>New Game</h1>
<ul class="list-unstyled d-flex gap-2">
<% @letters.each do |letter| %>
   <li class="bg-primary text-white fw-bold px-3 py-2 rounded">
      <%= letter %>
    </li>
<% end %>
</ul>
<form action="/score" method="post" data-turbo="false" class="mt-4">
  <div class="mb-3">
    <label for="word" class="form-label">What is the longest word you can find?</label>
    <div class="input-group">
      <input type="text" name="word" id="word" class="form-control" autofocus>
      <button type="submit" class="btn btn-primary">Play</button>
    </div>
  </div>
  <%= hidden_field_tag :authenticity_token, form_authenticity_token %>
  <%= hidden_field_tag :letters, @letters %>
</form>
</div>
